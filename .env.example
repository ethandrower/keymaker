# --- keymaker local config ---
# Copy to .env for docker-compose. Generate a real master key (see README):
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"

# Django
DJANGO_SECRET_KEY=dev-insecure-change-me
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,web

# Encryption master key (Fernet). Comma-separate to rotate (first = primary for new writes).
KEYMAKER_MASTER_KEY=GENERATE_ME

# Database (docker-compose overrides this to point at the db service)
DATABASE_URL=postgres://keymaker:keymaker@localhost:5434/keymaker

# Shared-account auth: one password the whole team uses (everyone is admin).
# Leave blank for passwordless entry. Bitbucket OAuth stays off until configured.
KEYMAKER_SHARED_PASSWORD=change-me-shared-password

# (Used only if/when Bitbucket OAuth is enabled later.)
KEYMAKER_ADMIN_USERNAMES=edrower

# Bitbucket OAuth (leave blank locally if using DEV_LOGIN)
BITBUCKET_WORKSPACE=citemed
BITBUCKET_CLIENT_ID=
BITBUCKET_CLIENT_SECRET=
# Public base URL used to build the OAuth callback, e.g. https://keymaker.citemed.com
KEYMAKER_BASE_URL=http://localhost:8000

# Seed demo environments on first boot (local convenience)
SEED_DEMO=1
