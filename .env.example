# --- keymaker local config ---
# Copy to .env for docker-compose. Generate a real master key (see README):
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"

# Django
DJANGO_SECRET_KEY=dev-insecure-change-me
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,web

# Encryption master key (Fernet). Comma-separate to rotate (first = primary for new writes).
KEYMAKER_MASTER_KEY=GENERATE_ME

# Database (docker-compose overrides this to point at the db service)
DATABASE_URL=postgres://keymaker:keymaker@localhost:5434/keymaker

# The ONE key. Logs you into the UI (paste as the password) AND authenticates
# agents/CLIs via "Authorization: Bearer <key>". Everyone who has it is an admin.
# Leave blank for passwordless local dev; production MUST set a strong value.
KEYMAKER_KEY=change-me-to-a-strong-key

# Public base URL (used for CSRF trusted origin in production), e.g. https://keymaker.citemed.com
KEYMAKER_BASE_URL=http://localhost:8000

# Seed demo environments on first boot (local convenience)
SEED_DEMO=1
